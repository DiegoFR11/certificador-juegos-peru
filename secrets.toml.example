# ─────────────────────────────────────────────────────────────
# PLANTILLA DE CREDENCIALES — Certificador de Juegos Perú
# ─────────────────────────────────────────────────────────────
# 1. Copia este archivo como .streamlit/secrets.toml (sin .example)
# 2. Reemplaza los hashes de contraseña con los generados por generar_hash.py
# 3. NUNCA subas secrets.toml al repositorio (ya está en .gitignore)
# 4. En Streamlit Cloud: pega este contenido en Settings > Secrets
# ─────────────────────────────────────────────────────────────

[credentials.usernames.admin]
name = "Administrador"
password = "$2b$12$REEMPLAZAR_CON_HASH_GENERADO"

[credentials.usernames.compliance]
name = "Equipo Compliance"
password = "$2b$12$REEMPLAZAR_CON_HASH_GENERADO"

[cookie]
name = "certificador_juegos_peru"
key  = "CAMBIAR_POR_CLAVE_ALEATORIA_LARGA"
expiry_days = 30
